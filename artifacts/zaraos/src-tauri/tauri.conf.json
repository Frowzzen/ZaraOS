{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "ZaraOS",
  "version": "0.1.0",
  "identifier": "com.zaraos.desktop",

  "build": {
    "beforeDevCommand": "pnpm --filter @workspace/zaraos run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @workspace/zaraos run build",
    "frontendDist": "../dist"
  },

  "app": {
    "withGlobalTauri": false,

    "windows": [
      {
        "title": "ZaraOS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],

    "security": {
      "csp": "default-src 'self' blob: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://cdn.jsdelivr.net https://storage.googleapis.com https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com http://localhost:11434 http://localhost:8080; img-src 'self' data: blob:; media-src 'self' blob: mediastream:;"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/zaraos-ollama.service": "resources/zaraos-ollama.service",
      "resources/zaraos-session.sh": "resources/zaraos-session.sh",
      "resources/zaraos-openbox.desktop": "resources/zaraos-openbox.desktop",
      "resources/lightdm.conf": "resources/lightdm.conf",
      "resources/zaraos-plymouth/zaraos.plymouth": "resources/zaraos-plymouth/zaraos.plymouth",
      "resources/zaraos-plymouth/zaraos.script": "resources/zaraos-plymouth/zaraos.script",
      "resources/install.sh": "resources/install.sh"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-dev", "libgtk-3-dev", "pactl", "brightnessctl", "network-manager", "openbox", "picom", "lightdm"]
      }
    }
  },

  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "scope": {
        "allow": [
          "$HOME/**",
          "$APPDATA/**",
          "$APPCONFIG/**"
        ],
        "deny": [
          "$HOME/.ssh/**",
          "$HOME/.gnupg/**"
        ]
      }
    }
  }
}
